FROM nginx:1.25-alpine

# Remove default nginx configuration to prevent conflicts
RUN rm /etc/nginx/conf.d/default.conf

# Copy configuration files into the image to avoid sshfs mount issues in dev
COPY ./nginx/nginx.conf /etc/nginx/nginx.conf
COPY ./nginx/conf.d/upstream.conf /etc/nginx/conf.d/upstream.conf
COPY ./nginx/conf.d/locations.conf /etc/nginx/conf.d/locations.conf
